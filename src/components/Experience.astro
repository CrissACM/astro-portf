---
import { experiences } from '../data/cv';
import ExperienceCard from './ExperienceCard.astro';
import SectionHeader from './ui/SectionHeader.astro';
---

<section id="experience" class="content-section relative scroll-mt-18 px-6 py-25 max-[760px]:scroll-mt-16 max-[760px]:px-4 max-[760px]:py-19">
  <div class="mx-auto w-full max-w-280">
    <SectionHeader
      eyebrow="01 / Career log"
      title="Work experience"
      description="Engineering products across healthcare, automation, mobile platforms, commerce, and data-intensive systems."
    />

    <ol class="relative mx-auto grid max-w-240 list-none gap-5 p-0 before:absolute before:top-4.5 before:bottom-4.5 before:left-3 before:w-px before:bg-linear-to-b before:from-[var(--accent)] before:to-[rgba(var(--accent-rgb),0.08)] before:shadow-[0_0_12px_rgba(var(--accent-rgb),0.3)]" aria-label="Work experience timeline">
      {experiences.map((experience) => (
        <li class="relative pl-11 max-[480px]:pl-8.5">
          <span class="absolute top-6.25 left-1.5 z-[2] h-3.25 w-3.25 rounded-full border-[3px] border-[var(--page)] bg-[var(--accent)] shadow-[0_0_0_1px_var(--accent),0_0_14px_var(--accent)]" aria-hidden="true"></span>
          <ExperienceCard experience={experience} />
        </li>
      ))}
    </ol>
  </div>
</section>
