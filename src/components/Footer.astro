---
import { Bio } from '../data/cv';
import Icon from './Icon.astro';
const year = new Date().getFullYear();
const links = [['about', 'About'], ['experience', 'Experience'], ['projects', 'Projects'], ['skills', 'Skills'], ['education', 'Education']] as const;
const socialLinks = [{ href: Bio.x, label: 'X', icon: 'x' }, { href: Bio.github, label: 'GitHub', icon: 'github' }, { href: Bio.linkedin, label: 'LinkedIn', icon: 'linkedin' }, { href: Bio.insta, label: 'Instagram', icon: 'instagram' }] as const;
---

<footer class="flex w-full justify-center bg-light dark:bg-dark">
  <div class="flex w-full max-w-[1200px] flex-col items-center gap-3.5 p-4 text-dark dark:text-light">
    <nav aria-label="Footer navigation" class="mt-2 flex w-full max-w-[800px] justify-center gap-8 md:flex-wrap md:gap-4 md:text-center">
      {links.map(([id, label]) => <a href={`#${id}`} class="text-[1.2rem] transition-colors duration-200 hover:text-primary focus-visible:outline-2 focus-visible:outline-primary md:text-base dark:hover:text-primaryDark">{label}</a>)}
    </nav>
    <nav aria-label="Social profiles" class="mt-4 flex items-center gap-8">
      {socialLinks.map(({ href, label, icon }) => <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label} class="inline-block h-7 w-7 transition duration-200 hover:-translate-y-1 hover:text-primary dark:hover:text-primaryDark"><Icon name={icon} class="h-full w-full" /></a>)}
    </nav>
    <p class="mt-6 text-center text-sm">&copy; {year} CrissACM. All rights reserved.</p>
  </div>
</footer>
