---
import { Image } from 'astro:assets';
import type { Project } from '../data/projects';
import Icon from './Icon.astro';
import TechTag from './ui/TechTag.astro';

interface Props { project: Project }
const { project } = Astro.props;
---

<dialog
  id={`project-${project.id}`}
  data-project-dialog
  aria-labelledby={`project-${project.id}-title`}
  class="m-auto max-h-[calc(100dvh-28px)] w-[min(calc(100%-28px),820px)] overflow-y-auto rounded-[17px] border border-[rgba(var(--accent-rgb),0.35)] bg-[linear-gradient(135deg,rgba(var(--accent-rgb),0.06),transparent_25%),var(--surface-solid)] p-5 text-[var(--text)] shadow-[0_30px_100px_rgba(0,0,0,0.55),0_0_45px_rgba(var(--accent-rgb),0.1)] backdrop:bg-[rgba(1,3,4,0.78)] backdrop:backdrop-blur-lg"
>
  <button type="button" data-dialog-close class="ml-auto flex h-10 w-10 cursor-pointer items-center justify-center rounded-[9px] border border-[var(--line)] bg-[rgba(var(--accent-rgb),0.04)] text-[var(--text)]" aria-label={`Close ${project.title} details`}>
    <Icon name="close" class="h-5 w-5" />
  </button>
  <Image
    src={project.image}
    alt={`${project.title} project screenshot`}
    widths={[400, 800, 1200]}
    sizes="(max-width: 832px) calc(100vw - 68px), 780px"
    loading="lazy"
    decoding="async"
    class="mt-2 block max-h-107.5 w-full rounded-[11px] border border-[var(--line)] object-cover"
  />
  <p class="mt-6 mb-2 inline-flex items-center gap-2.5 font-mono text-[11px] font-bold tracking-[0.16em] text-[var(--accent)] uppercase before:h-px before:w-5.5 before:bg-[var(--accent)] before:shadow-[0_0_8px_var(--accent)]">Project dossier</p>
  <h2 id={`project-${project.id}-title`} class="m-0 text-[clamp(1.8rem,5vw,2.7rem)] leading-[1.05] font-bold tracking-[-0.055em] text-[var(--text)]">{project.title}</h2>
  <time class="mt-1.25 font-mono text-[10px] text-[var(--muted)]">{project.date}</time>
  <div class="mt-4 flex flex-wrap gap-1.75">
    {project.tags.map((tag) => <TechTag>{tag}</TechTag>)}
  </div>
  <p class="mt-4.25 text-[15px] leading-[1.65] text-[var(--muted)]">{project.description}</p>

  {project.member && (
    <section aria-labelledby={`project-${project.id}-members`}>
      <h3 id={`project-${project.id}-members`} class="mt-6 text-[17px] leading-tight font-bold text-[var(--text)]">Collaborators</h3>
      <div class="mt-3 grid gap-2">
        {project.member.map((member) => (
          <div class="flex items-center gap-3 rounded-lg border border-[var(--line)] p-2">
            <img src={member.img} alt={member.name} loading="lazy" class="h-10 w-10 rounded-lg object-cover" />
            <span class="mr-auto text-sm font-medium">{member.name}</span>
            <a href={member.github} target="_blank" rel="noopener noreferrer" aria-label={`${member.name} on GitHub`} class="inline-flex h-8 w-8 items-center justify-center rounded-[10px] border border-[var(--line)] bg-[var(--surface)] text-[var(--muted)] transition-[color,border-color,transform,box-shadow] duration-200 hover:-translate-y-0.5 hover:border-[rgba(var(--accent-rgb),0.55)] hover:text-[var(--accent)]">
              <Icon name="github" class="h-4 w-4" />
            </a>
            <a href={member.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`${member.name} on LinkedIn`} class="inline-flex h-8 w-8 items-center justify-center rounded-[10px] border border-[var(--line)] bg-[var(--surface)] text-[var(--muted)] transition-[color,border-color,transform,box-shadow] duration-200 hover:-translate-y-0.5 hover:border-[rgba(var(--accent-rgb),0.55)] hover:text-[var(--accent)]">
              <Icon name="linkedin" class="h-4 w-4" />
            </a>
          </div>
        ))}
      </div>
    </section>
  )}

  <div class="mt-5.5 grid grid-cols-2 gap-2.5 max-[480px]:grid-cols-1">
    <a href={project.github} target="_blank" rel="noopener noreferrer" class="inline-flex min-h-12 items-center justify-center gap-2.25 rounded-[10px] border border-[var(--accent)] bg-[rgba(var(--accent-rgb),0.055)] px-5 text-sm font-bold text-[var(--text)] no-underline transition-[transform,box-shadow,background] duration-200 hover:-translate-y-0.5 hover:shadow-[0_0_30px_rgba(var(--accent-rgb),0.38)]">View source</a>
    <a href={project.webapp} target="_blank" rel="noopener noreferrer" class="inline-flex min-h-12 items-center justify-center gap-2.25 rounded-[10px] border border-[var(--accent)] bg-[var(--accent)] px-5 text-sm font-bold text-[var(--accent-contrast)] no-underline shadow-[0_0_24px_rgba(var(--accent-rgb),0.22)] transition-[transform,box-shadow,background] duration-200 hover:-translate-y-0.5 hover:shadow-[0_0_30px_rgba(var(--accent-rgb),0.38)]">Launch project <span aria-hidden="true">↗</span></a>
  </div>
</dialog>
