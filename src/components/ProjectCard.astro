---
import { Image } from 'astro:assets';
import type { Project } from '../data/projects';
import TechTag from './ui/TechTag.astro';

interface Props { project: Project }
const { project } = Astro.props;
---

<article data-project-card data-category={project.category} class="tech-card project-card min-w-0">
  <button
    type="button"
    data-project-open={`project-${project.id}`}
    aria-label={`View details for ${project.title}`}
    class="group flex min-h-107.5 h-full w-full cursor-pointer flex-col gap-3.5 p-3.75 text-left text-inherit max-[760px]:min-h-0"
  >
    <div class="relative overflow-hidden rounded-[9px] border border-[var(--line)] after:pointer-events-none after:absolute after:inset-0 after:bg-[linear-gradient(135deg,transparent_55%,rgba(var(--accent-rgb),0.12))]">
      <Image
        src={project.image}
        alt={`${project.title} preview`}
        widths={[400, 800]}
        sizes="(max-width: 760px) calc(100vw - 62px), (max-width: 1024px) 45vw, 350px"
        loading="lazy"
        decoding="async"
        class="block h-43.5 w-full object-cover transition-[filter,transform] duration-300 group-hover:scale-[1.025] group-hover:saturate-110 group-hover:contrast-105 max-[760px]:aspect-video max-[760px]:h-auto"
      />
    </div>
    <div class="flex flex-wrap gap-1.75">
      {project.tags.slice(0, 4).map((tag) => <TechTag>{tag}</TechTag>)}
    </div>
    <div class="flex flex-1 flex-col">
      <h3 class="m-0 text-[17px] leading-tight font-bold text-[var(--text)]">{project.title}</h3>
      <time class="mt-1.25 font-mono text-[10px] text-[var(--muted)]">{project.date}</time>
      <p class="mt-2.5 line-clamp-4 text-[13px] leading-[1.58] text-[var(--muted)]">{project.description}</p>
      <span class="mt-auto flex items-center justify-between pt-4 font-mono text-[10px] font-bold tracking-[0.08em] text-[var(--accent)] uppercase">
        Inspect build <span aria-hidden="true">[ ↗ ]</span>
      </span>
    </div>
  </button>
</article>
