  {name === 'x' && <path fill="currentColor" d="M18.24 2.25h3.31l-7.23 8.26 8.51 11.24h-6.66l-5.21-6.82-5.97 6.82H1.68l7.73-8.84L1.25 2.25h6.83l4.71 6.23 5.45-6.23Zm-1.16 17.52h1.83L7.08 4.13H5.11l11.97 15.64Z" />}
  {name === 'linkedin' && <path fill="currentColor" d="M5.28 3.4a1.74 1.74 0 1 0 0 3.48 1.74 1.74 0 0 0 0-3.48ZM3.75 8.5H6.8V20H3.75V8.5ZM9 8.5h2.92v1.57h.04c.4-.78 1.4-1.98 3.85-1.98 4.12 0 4.88 2.71 4.88 6.24V20h-3.04v-5.03c0-1.2-.02-2.75-1.67-2.75-1.68 0-1.94 1.31-1.94 2.66V20H9V8.5Z" />}
  {name === 'instagram' && <><rect x="3" y="3" width="18" height="18" rx="5.2" stroke="currentColor" stroke-width="2"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><circle cx="17.4" cy="6.6" r="1.15" fill="currentColor"/></>}
  {name === 'sun' && <><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/><path d="M12 2v2m0 16v2M4.93 4.93l1.42 1.42m11.3 11.3 1.42 1.42M2 12h2m16 0h2M4.93 19.07l1.42-1.42m11.3-11.3 1.42-1.42" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></>}
  {name === 'moon' && <path d="M20.2 15.2A8.5 8.5 0 0 1 8.8 3.8 8.5 8.5 0 1 0 20.2 15.2Z" fill="currentColor"/>}
  {name === 'external' && <path d="M11 5H6a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h11a2 2 0 0 0 2-2v-5M14 4h6v6m0-6L10 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>}
  {name === 'close' && <path d="m6 6 12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>}
</svg>
