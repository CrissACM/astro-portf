---
import { education } from '../data/cv';
import EducationCard from './EducationCard.astro';
---

<section id="education" class="relative z-[1] scroll-mt-20 px-4 pb-[60px] mg:p-4">
  <div class="mx-auto flex w-full max-w-[1350px] flex-col items-center gap-3 pt-10">
    <h2 class="mt-5 text-center text-[42px] font-semibold text-dark md:mt-3 md:text-[32px] dark:text-light">Education</h2>
    <p class="mt-3 max-w-[600px] text-center text-lg text-dark/70 md:text-base dark:text-light/70">My education has been a journey of discovery and growth that continues.</p>
    <ol class="mt-5 w-full max-w-[1000px]" aria-label="Education timeline">
      {education.map((item, index) => (
        <li class="grid grid-cols-[1fr_28px] gap-3">
          <div class="pb-6"><EducationCard education={item} /></div>
          <div class="flex flex-col items-center" aria-hidden="true"><span class="mt-5 h-4 w-4 rounded-full border-2 border-primaryDark bg-light dark:border-primary dark:bg-dark"></span>{index < education.length - 1 && <span class="min-h-8 w-0.5 flex-1 bg-primary dark:bg-primaryDark"></span>}</div>
        </li>
      ))}
    </ol>
  </div>
</section>
