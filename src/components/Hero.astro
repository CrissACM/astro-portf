---
import { Image } from 'astro:assets';
import profileImage from '../assets/profile/profile.jpeg';
import { Bio } from '../data/cv';
import HeroAnimation from './HeroAnimation.astro';
import Icon from './Icon.astro';

const socialLinks = [
  { href: Bio.x, label: 'X', icon: 'x' },
  { href: Bio.github, label: 'GitHub', icon: 'github' },
  { href: Bio.linkedin, label: 'LinkedIn', icon: 'linkedin' },
  { href: Bio.insta, label: 'Instagram', icon: 'instagram' },
] as const;
---

<section id="about" class="scroll-mt-20">
  <div class="relative z-[1] flex justify-center bg-card px-[30px] py-20 [clip-path:polygon(0_0,100%_0,100%_100%,70%_95%,0_100%)] sm:px-4 sm:py-8 mg:px-4 mg:py-[66px] dark:bg-carDarkL">
    <div aria-hidden="true" class="absolute inset-0 left-2/4 top-2/4 flex h-full w-full max-w-[1360px] -translate-x-2/4 -translate-y-2/4 justify-end overflow-hidden px-[30px] mg:justify-center mg:p-0">
      <HeroAnimation />
    </div>
    <div class="relative flex w-full max-w-[1100px] items-center justify-between mg:flex-col">
      <div class="order-1 w-full sm:order-2 sm:mb-[30px] sm:flex sm:flex-col sm:items-center mg:order-2 mg:mb-[30px] mg:flex mg:flex-col mg:items-center">
        <h1 class="truncate text-[45px] font-bold leading-[68px] text-dark sm:mb-2 sm:text-[32px] sm:leading-[48px] mg:text-center dark:text-light">
          Hi, I am <br />{Bio.name}
        </h1>
        <p class="flex min-h-[76px] items-center gap-3 text-[30px] font-semibold leading-tight text-dark sm:mb-4 sm:min-h-[72px] sm:text-[22px] mg:justify-center mg:text-center dark:text-light">
          <span data-typewriter data-roles={JSON.stringify(Bio.roles)} class="text-balance text-primary dark:text-primaryDark">{Bio.roles[0]}</span>
        </p>
        <p class="text-lg leading-8 text-dark/70 sm:text-base sm:leading-8 mg:text-center dark:text-light/70">{Bio.description}</p>
        <nav aria-label="Social profiles" class="my-6 flex h-16 w-full items-center justify-around sm:my-2 mg:justify-evenly">
          {socialLinks.map(({ href, label, icon }) => (
            <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label} class="w-10 text-dark transition duration-200 hover:scale-110 active:scale-95 dark:text-light">
              <Icon name={icon} class="h-10 w-10" />
            </a>
          ))}
        </nav>
        <a href={Bio.resume} target="_blank" rel="noopener noreferrer" class="mb-4 flex w-[95%] max-w-[300px] cursor-pointer justify-center rounded-[20px] bg-gradient-to-br from-purple-600 to-fuchsia-500 px-0 py-4 text-center text-xl font-semibold text-white no-underline shadow-[10px_10px_0_#1f2634,-10px_-10px_0_#1f2634] transition duration-200 hover:scale-105 hover:brightness-110 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary sm:py-4 sm:text-lg dark:from-sky-500 dark:to-cyan-400">
          Check Resume <Icon name="external" class="ml-2 h-6 w-6" />
        </a>
      </div>
      <div class="order-2 flex w-full justify-end gap-3 sm:mb-[30px] mg:order-1 mg:mb-20 mg:items-center mg:justify-center">
        <Image src={profileImage} alt="Cristobal Colmenares" widths={[250, 280, 400]} sizes="(max-width: 767px) 250px, (max-width: 960px) 280px, 400px" loading="eager" class="relative -top-16 aspect-square h-full max-h-[400px] w-full max-w-[400px] rounded-full border-2 border-primary object-cover sm:max-h-[280px] sm:max-w-[280px] md:max-h-[250px] md:max-w-[250px] mg:top-0 dark:border-primaryDark" />
      </div>
    </div>
  </div>
</section>

<script>
  const target = document.querySelector<HTMLElement>('[data-typewriter]');
  if (target && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const roles = JSON.parse(target.dataset.roles ?? '[]') as string[];
    let roleIndex = 0;
    let charIndex = roles[0]?.length ?? 0;
    let deleting = true;
    const tick = () => {
      const role = roles[roleIndex] ?? '';
      charIndex += deleting ? -1 : 1;
      target.textContent = role.slice(0, charIndex);
      if (!deleting && charIndex >= role.length) {
        deleting = true;
        window.setTimeout(tick, 1500);
        return;
      }
      if (deleting && charIndex <= 0) {
        deleting = false;
        roleIndex = (roleIndex + 1) % roles.length;
      }
      window.setTimeout(tick, deleting ? 40 : 75);
    };
    window.setTimeout(tick, 1200);
  }
</script>
