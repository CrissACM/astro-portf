---
import type { Education } from '../data/cv';
interface Props { education: Education }
const { education } = Astro.props;
---

<article class="tech-card p-5.5 max-[480px]:p-4.25">
  <div class="flex items-start gap-3.5">
    <div class="relative flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-[10px] border border-[rgba(var(--accent-rgb),0.25)] bg-[rgba(var(--accent-rgb),0.08)] font-mono font-extrabold text-[var(--accent)]">
      <span aria-hidden="true">{education.school.charAt(0)}</span>
      {education.img && <img src={education.img} alt={`${education.school} logo`} loading="lazy" class="absolute inset-0 h-full w-full bg-[var(--surface-raised)] object-contain" />}
    </div>
    <div>
      <h3 class="m-0 text-[17px] leading-tight font-bold text-[var(--text)]">{education.school}</h3>
      <p class="mt-1 text-[13px] font-semibold text-[color-mix(in_srgb,var(--accent)_72%,var(--text))]">{education.degree}</p>
      <p class="mt-1.25 font-mono text-[10px] text-[var(--muted)]">{education.location} · {education.date}</p>
    </div>
  </div>
  <p class="mt-4.25 text-sm leading-[1.65] text-[var(--muted)]">{education.desc}</p>
</article>
