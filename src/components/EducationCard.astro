---
import type { Education } from '../data/cv';
interface Props { education: Education }
const { education } = Astro.props;
---

<article class="relative flex w-full flex-col justify-between gap-3 overflow-hidden rounded-[10px] border border-primary px-4 py-3 shadow-[rgba(23,92,230,0.15)_0_4px_24px] transition duration-300 ease-in-out hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(0,0,0,0.2)] md:gap-2 md:p-2.5 dark:border-primaryDark">
  <div class="flex w-full gap-3">{education.img && <img src={education.img} alt={`${education.school} logo`} loading="lazy" class="mt-1 h-[50px] w-[50px] rounded-[10px] bg-dark object-contain md:h-10 md:w-10 dark:bg-light" />}<div class="flex w-full flex-col"><h3 class="text-lg font-semibold text-dark md:text-sm dark:text-light">{education.school}</h3><p class="text-sm font-medium text-dark/70 md:text-xs dark:text-light/70">{education.degree}</p><p class="text-xs text-dark/60 md:text-[10px] dark:text-light/60">{education.location}</p><time class="text-xs text-dark/70 md:text-[10px] dark:text-light/70">{education.date}</time></div></div>
  <p class="text-[15px] text-dark md:text-xs dark:text-light">{education.desc}</p>
</article>
