---
import { skills } from '../data/cv';
import SectionHeader from './ui/SectionHeader.astro';
---

<section id="skills" class="content-section relative scroll-mt-18 px-6 py-25 max-[760px]:scroll-mt-16 max-[760px]:px-4 max-[760px]:py-19">
  <div class="mx-auto w-full max-w-280">
    <SectionHeader
      eyebrow="03 / Capability matrix"
      title="Skills"
      description="Technologies, platforms, and professional strengths from production work and continuous practice."
    />

    <div class="grid grid-cols-2 gap-5 max-[760px]:grid-cols-1">
      {skills.map((group) => (
        <article class="tech-card skill-card p-6 max-[480px]:p-4.25">
          <p class="mb-2.75 font-mono text-[10px] font-bold tracking-[0.15em] text-[var(--muted)] uppercase">Module / {group.title}</p>
          <h3 class="m-0 text-xl leading-tight font-bold text-[var(--text)]">{group.title}</h3>
          <ul class="mt-4.5 flex list-none flex-wrap gap-2.25 p-0">
            {group.skills.map((item) => (
              <li class="inline-flex min-h-10.5 items-center gap-2 rounded-[9px] border border-[var(--line)] bg-[rgba(var(--accent-rgb),0.025)] px-2.75 py-2 text-xs text-[var(--text)] transition-[border-color,background] duration-200 hover:border-[rgba(var(--accent-rgb),0.35)] hover:bg-[rgba(var(--accent-rgb),0.07)]">
                {group.title !== 'Professional' && (
                  item.image
                    ? <img src={item.image} alt="" loading="lazy" decoding="async" class="flex h-6.25 w-6.25 items-center justify-center rounded-md object-contain" />
                    : <span aria-hidden="true" class="flex h-6.25 w-6.25 items-center justify-center rounded-md bg-[rgba(var(--accent-rgb),0.09)] font-mono text-[9px] font-extrabold text-[var(--accent)]">{item.name.slice(0, 2).toUpperCase()}</span>
                )}
                {item.name}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
