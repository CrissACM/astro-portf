---
import type { Experience } from '../data/cv';
import TechTag from './ui/TechTag.astro';
interface Props { experience: Experience }
const { experience } = Astro.props;
---

<article class="tech-card p-5.5 max-[480px]:p-4.25">
  <div class="flex items-start gap-3.5">
    <div class="relative flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-[10px] border border-[rgba(var(--accent-rgb),0.25)] bg-[rgba(var(--accent-rgb),0.08)] font-mono font-extrabold text-[var(--accent)]">
      <span aria-hidden="true">{experience.company.charAt(0)}</span>
      {experience.img && <img data-company-logo src={experience.img} alt={`${experience.company} logo`} loading="lazy" class="absolute inset-0 h-full w-full bg-[var(--surface-raised)] object-contain" />}
    </div>
    <div>
      <h3 class="m-0 text-[17px] leading-tight font-bold text-[var(--text)]">{experience.role}</h3>
      <p class="mt-1 text-[13px] font-semibold text-[color-mix(in_srgb,var(--accent)_72%,var(--text))]">{experience.company}</p>
      <p class="mt-1.25 font-mono text-[10px] text-[var(--muted)]">{experience.location} · {experience.date}</p>
    </div>
  </div>

  <p class="mt-4.25 text-sm leading-[1.65] text-[var(--muted)]">{experience.desc}</p>
  {experience.highlights.length > 0 && (
    <ul class="mt-3.5 grid list-none gap-2 p-0 text-[13px] leading-[1.55] text-[var(--muted)]">
      {experience.highlights.map((highlight) => <li class="relative pl-4.25 before:absolute before:top-0 before:left-0 before:font-mono before:text-[var(--accent)] before:content-['+']">{highlight}</li>)}
    </ul>
  )}
  <div class="mt-4 flex flex-wrap gap-1.75" aria-label="Technologies used">
    {experience.skills.map((skill) => <TechTag>{skill}</TechTag>)}
  </div>
</article>

<script>
  document.querySelectorAll<HTMLImageElement>('[data-company-logo]').forEach((image) => {
    const showFallback = () => image.classList.add('hidden');
    image.addEventListener('error', showFallback, { once: true });
    if (image.complete && image.naturalWidth === 0) showFallback();
  });
</script>
