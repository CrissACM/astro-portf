---
import { projects, type ProjectCategory } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
import ProjectDetails from './ProjectDetails.astro';
import SectionHeader from './ui/SectionHeader.astro';

const filters: Array<{ value: 'all' | ProjectCategory; label: string }> = [
  { value: 'all', label: 'All systems' },
  { value: 'vanilla', label: 'Vanilla' },
  { value: 'web app', label: 'Web apps' },
  { value: 'mobile app', label: 'Mobile apps' },
];
---

<section id="projects" class="content-section relative scroll-mt-18 px-6 py-25 max-[760px]:scroll-mt-16 max-[760px]:px-4 max-[760px]:py-19">
  <div class="mx-auto w-full max-w-280">
    <SectionHeader
      eyebrow="02 / Selected builds"
      title="Projects"
      description="A selection of web, mobile, and product experiments built to solve practical problems."
    />

    <div role="group" aria-label="Filter projects" class="mx-auto mb-7.5 flex w-fit max-w-full gap-0 overflow-x-auto rounded-[11px] border border-[var(--line)] bg-[var(--surface)] p-1.25">
      {filters.map(({ value, label }) => (
        <button
          type="button"
          data-project-filter={value}
          aria-pressed={value === 'all' ? 'true' : 'false'}
          class="cursor-pointer whitespace-nowrap rounded-[7px] border-0 bg-transparent px-3.5 py-2.25 text-xs font-semibold text-[var(--muted)] transition-[color,background,box-shadow] duration-200 hover:bg-[rgba(var(--accent-rgb),0.11)] hover:text-[var(--text)] hover:shadow-[inset_0_0_0_1px_rgba(var(--accent-rgb),0.22)] aria-pressed:bg-[rgba(var(--accent-rgb),0.11)] aria-pressed:text-[var(--text)] aria-pressed:shadow-[inset_0_0_0_1px_rgba(var(--accent-rgb),0.22)]"
        >
          {label}
        </button>
      ))}
    </div>

    <div data-project-grid class="grid grid-cols-3 gap-5 max-[1024px]:grid-cols-2 max-[760px]:grid-cols-1">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </div>
</section>
{projects.map((project) => <ProjectDetails project={project} />)}

<script>
  import { initProjects } from '../scripts/projects';

  initProjects();
</script>
